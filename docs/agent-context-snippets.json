[
  {
    "title": "Retrieve mixed project context",
    "command": "curl -s -H \"Authorization: Bearer $PAIMOS_API_KEY\" -H \"Content-Type: application/json\" \"$PAIMOS_URL/api/projects/$PROJECT_ID/retrieve\" -d '{\"q\":\"password reset flow\",\"k\":10}'"
  },
  {
    "title": "Inspect the project graph",
    "command": "curl -s -H \"Authorization: Bearer $PAIMOS_API_KEY\" \"$PAIMOS_URL/api/projects/$PROJECT_ID/graph?root=project:$PROJECT_ID&depth=2\""
  },
  {
    "title": "Blast radius of an issue",
    "command": "curl -s -H \"Authorization: Bearer $PAIMOS_API_KEY\" \"$PAIMOS_URL/api/projects/$PROJECT_ID/graph/blast-radius?issue=PAI-79&depth=3\""
  }
]
