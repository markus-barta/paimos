{
  "name": "paimos-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "schema:generate": "cd .. && cd backend && go run ../scripts/generate-frontend-schema.go",
    "schema:check": "npm run schema:generate && git diff --exit-code -- src/types/generated/schema.ts",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:e2e": "playwright test",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fontsource/bricolage-grotesque": "^5.2.10",
    "@fontsource/dm-sans": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "dompurify": "^3.3.3",
    "force-graph": "^1.51.4",
    "lucide-vue-next": "^0.577.0",
    "marked": "^17.0.4",
    "pinia": "^3.0.4",
    "vue": "^3.5.0",
    "vue-i18n": "^11.3.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/dompurify": "^3.0.5",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vue/eslint-config-typescript": "^14.9.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "happy-dom": "^20.9.0",
    "prettier": "^3.8.4",
    "typescript": "^5.7.0",
    "vite": "^6.1.0",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.2.0"
  },
  "overrides": {
    "picomatch": ">=4.0.4"
  }
}
