{
  "openapi": "3.1.0",
  "info": {
    "title": "PAIMOS API",
    "description": "PAIMOS — Professional & Personal AI Project OS. Stable HTTP API used by the SPA, the paimos CLI, and any custom integration. Authentication is either a session cookie (browser) or a `paimos_*` bearer API key (machine-to-machine).",
    "version": "1.0.0",
    "license": { "name": "AGPL-3.0-only" }
  },
  "servers": [
    { "url": "/", "description": "Same-origin (recommended)" }
  ],
  "tags": [
    { "name": "auth", "description": "Login, session, password reset, TOTP, profile" },
    { "name": "users", "description": "User management (admin)" },
    { "name": "projects", "description": "Projects" },
    { "name": "issues", "description": "Issues — backlog items, sprints, tickets" },
    { "name": "comments", "description": "Issue comments" },
    { "name": "time-entries", "description": "Time tracking" },
    { "name": "attachments", "description": "File attachments on issues" },
    { "name": "documents", "description": "Customer- and project-scoped documents" },
    { "name": "incidents", "description": "Incident log (PAI-116, NIS2 readiness)" },
    { "name": "gdpr", "description": "Per-subject export / erasure (PAI-117)" },
    { "name": "schema", "description": "Self-describing schema + health" }
  ],
  "components": {
    "securitySchemes": {
      "sessionCookie": {
        "type": "apiKey",
        "in": "cookie",
        "name": "session",
        "description": "Issued by POST /api/auth/login. Browser SPA. CSRF-protected via X-CSRF-Token header for mutations (PAI-113)."
      },
      "bearerAPIKey": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "paimos_*",
        "description": "Long-lived API key, prefix configurable via BRAND_API_KEY_PREFIX. Created via /api/auth/api-keys."
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "required": ["error"],
        "properties": {
          "error": { "type": "string", "description": "Human-readable error message" }
        }
      },
      "User": {
        "type": "object",
        "required": ["id", "username", "role", "status"],
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "username": { "type": "string" },
          "role": { "type": "string", "enum": ["admin", "member", "external"] },
          "status": { "type": "string", "enum": ["active", "inactive", "deleted"] },
          "first_name": { "type": "string" },
          "last_name": { "type": "string" },
          "nickname": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "locale": { "type": "string" },
          "timezone": { "type": "string" },
          "issue_auto_refresh_enabled": { "type": "boolean" },
          "issue_auto_refresh_interval_seconds": { "type": "integer", "minimum": 10, "default": 60 },
          "created_at": { "type": "string", "format": "date-time" },
          "last_login_at": { "type": "string", "format": "date-time", "nullable": true }
        }
      },
      "AccessResponse": {
        "type": "object",
        "properties": {
          "all_projects": { "type": "boolean" },
          "levels": {
            "type": "object",
            "additionalProperties": { "type": "string", "enum": ["viewer", "editor"] },
            "description": "project_id → access level"
          }
        }
      },
      "MeResponse": {
        "type": "object",
        "properties": {
          "user": { "$ref": "#/components/schemas/User" },
          "access": { "$ref": "#/components/schemas/AccessResponse" }
        }
      },
      "Project": {
        "type": "object",
        "required": ["id", "name", "key"],
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "name": { "type": "string" },
          "key": { "type": "string", "description": "Short alphanumeric prefix (e.g. PAI)" },
          "description": { "type": "string" },
          "status": { "type": "string", "enum": ["active", "archived"] },
          "customer_id": { "type": "integer", "format": "int64", "nullable": true },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "Issue": {
        "type": "object",
        "required": ["id", "project_id", "title", "type", "status"],
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "project_id": { "type": "integer", "format": "int64", "nullable": true },
          "title": { "type": "string" },
          "type": { "type": "string", "enum": ["epic", "cost_unit", "release", "sprint", "ticket", "task"] },
          "status": { "type": "string", "enum": ["new", "backlog", "in-progress", "qa", "done", "delivered", "accepted", "invoiced", "cancelled"] },
          "priority": { "type": "string", "enum": ["low", "medium", "high"] },
          "description": { "type": "string" },
          "acceptance_criteria": { "type": "string" },
          "notes": { "type": "string" },
          "parent_id": { "type": "integer", "format": "int64", "nullable": true },
          "assignee_id": { "type": "integer", "format": "int64", "nullable": true },
          "cost_unit": { "type": "string" },
          "release": { "type": "string" },
          "issue_number": { "type": "integer" },
          "key": { "type": "string", "description": "Human-friendly identifier {project_key}-{issue_number}" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "Comment": {
        "type": "object",
        "required": ["id", "issue_id", "body", "created_at"],
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "issue_id": { "type": "integer", "format": "int64" },
          "author_id": { "type": "integer", "format": "int64", "nullable": true },
          "body": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "TimeEntry": {
        "type": "object",
        "required": ["id", "issue_id", "user_id", "started_at"],
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "issue_id": { "type": "integer", "format": "int64" },
          "user_id": { "type": "integer", "format": "int64" },
          "started_at": { "type": "string", "format": "date-time" },
          "stopped_at": { "type": "string", "format": "date-time", "nullable": true },
          "comment": { "type": "string" }
        }
      },
      "Attachment": {
        "type": "object",
        "required": ["id", "issue_id", "filename", "content_type", "size_bytes"],
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "issue_id": { "type": "integer", "format": "int64" },
          "filename": { "type": "string" },
          "content_type": { "type": "string" },
          "size_bytes": { "type": "integer", "format": "int64" },
          "uploaded_by": { "type": "integer", "format": "int64" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "Document": {
        "type": "object",
        "required": ["id", "scope", "filename", "mime_type", "size_bytes"],
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "scope": { "type": "string", "enum": ["customer", "project"] },
          "customer_id": { "type": "integer", "format": "int64", "nullable": true },
          "project_id": { "type": "integer", "format": "int64", "nullable": true },
          "filename": { "type": "string" },
          "mime_type": { "type": "string" },
          "size_bytes": { "type": "integer", "format": "int64" },
          "label": { "type": "string" },
          "status": { "type": "string", "enum": ["draft", "active", "expired"] },
          "valid_from": { "type": "string", "format": "date", "nullable": true },
          "valid_until": { "type": "string", "format": "date", "nullable": true },
          "uploaded_at": { "type": "string", "format": "date-time" }
        }
      },
      "Incident": {
        "type": "object",
        "required": ["id", "severity", "kind", "title", "status", "detected_at"],
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
          "kind": { "type": "string" },
          "title": { "type": "string" },
          "summary": { "type": "string" },
          "details": { "type": "string" },
          "status": { "type": "string", "enum": ["open", "investigating", "resolved", "closed"] },
          "reported_by": { "type": "integer", "format": "int64", "nullable": true },
          "detected_at": { "type": "string", "format": "date-time" },
          "resolved_at": { "type": "string", "format": "date-time", "nullable": true }
        }
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "Missing or invalid credentials",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
      },
      "Forbidden": {
        "description": "Authenticated but insufficient privilege",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
      },
      "NotFound": {
        "description": "Resource not found, or hidden from caller for privacy",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
      }
    }
  },
  "security": [
    { "sessionCookie": [] },
    { "bearerAPIKey": [] }
  ],
  "paths": {
    "/api/health": {
      "get": {
        "tags": ["schema"],
        "summary": "Liveness probe",
        "security": [],
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "type": "object", "properties": { "status": { "type": "string" }, "service": { "type": "string" }, "version": { "type": "string", "description": "App version (semver) stamped at build time, or 'dev' for local builds." } } } } }
          }
        }
      }
    },
    "/api/schema": {
      "get": {
        "tags": ["schema"],
        "summary": "Self-describing schema (enums, transitions, entity shapes)",
        "security": [],
        "responses": {
          "200": { "description": "Schema document" }
        }
      }
    },
    "/api/openapi.json": {
      "get": {
        "tags": ["schema"],
        "summary": "This OpenAPI document",
        "security": [],
        "responses": { "200": { "description": "OpenAPI 3.1 JSON" } }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["auth"],
        "summary": "Username/password login",
        "security": [],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "required": ["username", "password"], "properties": { "username": { "type": "string" }, "password": { "type": "string" } } } } }
        },
        "responses": {
          "200": { "description": "Logged in", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MeResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "description": "Rate-limited" }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "tags": ["auth"],
        "summary": "Drop the current session",
        "responses": { "204": { "description": "Logged out" } }
      }
    },
    "/api/auth/me": {
      "get": {
        "tags": ["auth"],
        "summary": "Current authenticated user + project access summary",
        "responses": {
          "200": { "description": "Current user", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MeResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "patch": {
        "tags": ["auth"],
        "summary": "Update current user's profile and preferences",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object" } } }
        },
        "responses": {
          "200": { "description": "Updated user", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/User" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/auth/forgot": {
      "post": {
        "tags": ["auth"],
        "summary": "Begin password reset (always returns 202 to prevent enumeration)",
        "security": [],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "required": ["email"], "properties": { "email": { "type": "string", "format": "email" } } } } } },
        "responses": { "202": { "description": "Accepted" } }
      }
    },
    "/api/auth/reset": {
      "post": {
        "tags": ["auth"],
        "summary": "Complete password reset",
        "security": [],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "required": ["token", "new_password"], "properties": { "token": { "type": "string" }, "new_password": { "type": "string" } } } } } },
        "responses": { "200": { "description": "Password updated" }, "400": { "description": "Invalid token or password" } }
      }
    },
    "/api/users": {
      "get": {
        "tags": ["users"],
        "summary": "List users",
        "responses": {
          "200": { "description": "Users", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/User" } } } } }
        }
      },
      "post": {
        "tags": ["users"],
        "summary": "Create user (admin)",
        "responses": { "201": { "description": "Created" }, "403": { "$ref": "#/components/responses/Forbidden" } }
      }
    },
    "/api/users/{id}/gdpr-export": {
      "get": {
        "tags": ["gdpr", "users"],
        "summary": "Per-subject GDPR export (admin)",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } }],
        "responses": {
          "200": { "description": "Subject export", "content": { "application/json": {} } },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/users/{id}/gdpr-erase": {
      "post": {
        "tags": ["gdpr", "users"],
        "summary": "Erase subject (anonymise + drop sessions/api keys)",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } }],
        "responses": { "200": { "description": "Erased" }, "400": { "description": "Cannot erase self" } }
      }
    },
    "/api/projects": {
      "get": {
        "tags": ["projects"],
        "summary": "List projects",
        "responses": { "200": { "description": "Projects", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Project" } } } } } }
      },
      "post": {
        "tags": ["projects"],
        "summary": "Create project (admin)",
        "responses": { "201": { "description": "Created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Project" } } } } }
      }
    },
    "/api/projects/{id}": {
      "get": {
        "tags": ["projects"],
        "summary": "Get project",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } }],
        "responses": { "200": { "description": "Project", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Project" } } } }, "404": { "$ref": "#/components/responses/NotFound" } }
      },
      "put": {
        "tags": ["projects"],
        "summary": "Update project (admin)",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } }],
        "responses": { "200": { "description": "Updated" } }
      },
      "delete": {
        "tags": ["projects"],
        "summary": "Soft-delete project (admin)",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } }],
        "responses": { "204": { "description": "Deleted" } }
      }
    },
    "/api/projects/{id}/issues": {
      "get": {
        "tags": ["issues", "projects"],
        "summary": "List issues in project",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } }],
        "responses": { "200": { "description": "Issues", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Issue" } } } } } }
      },
      "post": {
        "tags": ["issues", "projects"],
        "summary": "Create issue in project",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } }],
        "responses": { "201": { "description": "Created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Issue" } } } } }
      }
    },
    "/api/issues": {
      "get": {
        "tags": ["issues"],
        "summary": "List or look up issues across projects",
        "responses": { "200": { "description": "Issues", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Issue" } } } } } }
      }
    },
    "/api/issues/{id}": {
      "get": {
        "tags": ["issues"],
        "summary": "Get issue (numeric id or {project_key}-{n})",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Issue", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Issue" } } } }, "404": { "$ref": "#/components/responses/NotFound" } }
      },
      "put": {
        "tags": ["issues"],
        "summary": "Update issue",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Updated" } }
      },
      "patch": {
        "tags": ["issues"],
        "summary": "Update issue",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Updated" } }
      }
    },
    "/api/issues/{id}/comments": {
      "get": {
        "tags": ["comments"],
        "summary": "List comments on issue",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Comments", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Comment" } } } } } }
      },
      "post": {
        "tags": ["comments"],
        "summary": "Create comment on issue",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "201": { "description": "Created" } }
      }
    },
    "/api/issues/{id}/time-entries": {
      "get": {
        "tags": ["time-entries"],
        "summary": "List time entries on issue",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Time entries", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/TimeEntry" } } } } } }
      },
      "post": {
        "tags": ["time-entries"],
        "summary": "Start a time entry on issue",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "201": { "description": "Started" } }
      }
    },
    "/api/issues/{id}/attachments": {
      "get": {
        "tags": ["attachments"],
        "summary": "List attachments on issue",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Attachments", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Attachment" } } } } } }
      },
      "post": {
        "tags": ["attachments"],
        "summary": "Upload attachment (multipart/form-data)",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": { "required": true, "content": { "multipart/form-data": { "schema": { "type": "object", "properties": { "file": { "type": "string", "format": "binary" } } } } } },
        "responses": { "201": { "description": "Created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Attachment" } } } } }
      }
    },
    "/api/documents/{id}/download": {
      "get": {
        "tags": ["documents"],
        "summary": "Download a document (scope-aware authz, PAI-111)",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } }],
        "responses": {
          "200": { "description": "Document bytes", "content": { "application/octet-stream": {} } },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/incidents": {
      "get": {
        "tags": ["incidents"],
        "summary": "List incidents (admin)",
        "parameters": [
          { "name": "status", "in": "query", "schema": { "type": "string", "enum": ["open", "investigating", "resolved", "closed"] } },
          { "name": "severity", "in": "query", "schema": { "type": "string", "enum": ["low", "medium", "high", "critical"] } },
          { "name": "since", "in": "query", "schema": { "type": "string", "format": "date-time" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "minimum": 1, "maximum": 1000, "default": 100 } }
        ],
        "responses": { "200": { "description": "Incidents", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Incident" } } } } } }
      },
      "post": {
        "tags": ["incidents"],
        "summary": "Create an incident (admin)",
        "responses": { "201": { "description": "Created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Incident" } } } } }
      }
    },
    "/api/incidents/{id}": {
      "get": {
        "tags": ["incidents"],
        "summary": "Get incident (admin)",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } }],
        "responses": { "200": { "description": "Incident", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Incident" } } } } }
      },
      "patch": {
        "tags": ["incidents"],
        "summary": "Update incident (admin)",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } }],
        "responses": { "200": { "description": "Updated" } }
      },
      "delete": {
        "tags": ["incidents"],
        "summary": "Delete incident (admin)",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } }],
        "responses": { "204": { "description": "Deleted" } }
      }
    },
    "/api/incidents/export": {
      "get": {
        "tags": ["incidents"],
        "summary": "Export incidents (admin) — JSON or CSV for SIEM ingestion",
        "parameters": [{ "name": "format", "in": "query", "schema": { "type": "string", "enum": ["json", "csv"], "default": "json" } }],
        "responses": { "200": { "description": "Export" } }
      }
    },
    "/api/gdpr/retention": {
      "get": {
        "tags": ["gdpr"],
        "summary": "Active retention policy (admin)",
        "responses": { "200": { "description": "Policy" } }
      }
    }
  }
}
