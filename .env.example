# PAIMOS environment variables
# Copy to .env and fill in real values. All are optional; defaults shown.

# === Core server ===
# PORT=8888
# STATIC_DIR=/app/static
# DATA_DIR=/app/data
# ADMIN_PASSWORD=               # first-run seed only
# COOKIE_SECURE=true            # set on HTTPS deployments
# INSTANCE_LABEL=               # shows a banner in sidebar (e.g. "STAGING")

# === Branding (all optional; defaults shown) ===
# BRAND_PRODUCT_NAME=PAIMOS
# BRAND_COMPANY_NAME=           # blank default; appears in page title / email footer if set
# BRAND_WEBSITE_URL=https://paimos.com
# BRAND_PUBLIC_URL=             # required for password-reset magic links
# BRAND_EMAIL_FROM=             # required when SMTP configured
# BRAND_TOTP_ISSUER=            # defaults to BRAND_PRODUCT_NAME
# BRAND_HEALTH_SERVICE_NAME=    # defaults to lowercase(BRAND_PRODUCT_NAME)
# BRAND_PAGE_TITLE=             # defaults to BRAND_PRODUCT_NAME (+ " — " + BRAND_COMPANY_NAME if set)
# BRAND_API_KEY_PREFIX=paimos_  # SET-ONCE: changing after keys exist orphans them
# BRAND_DB_FILENAME=paimos.db   # SET-ONCE: change only on empty DATA_DIR
# BRAND_MINIO_BUCKET=paimos-attachments  # SET-ONCE

# === Email (SMTP) ===
# SMTP_HOST=                    # unset = dev mode (reset links logged to stdout)
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# === Attachments (MinIO / S3) ===
# MINIO_ENDPOINT=               # unset = attachments disabled
# MINIO_ACCESS_KEY=
# MINIO_SECRET_KEY=
# MINIO_USE_SSL=false
